{
  "name": "nonoise-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "NONoise Framework monorepo — create-nonoise CLI + templates + skills",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter create-nonoise run build",
