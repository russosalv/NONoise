# Azure DevOps configuration — copy this file to `.env` and fill the values.
# The tool reads these variables at runtime; nothing is hardcoded in the source.

# Organization URL, e.g. https://dev.azure.com/my-org
AZURE_DEVOPS_ORG=

# Project name (URL-encode spaces as %20, e.g. My%20Project)
AZURE_DEVOPS_PROJECT=

# Personal Access Token — scopes required: Work Items (Read & Write)
AZURE_DEVOPS_PAT=

# Iteration path, e.g. "My Project\Sprint 5"
AZURE_DEVOPS_ITERATION_PATH=

# Area path, e.g. "My Project"
AZURE_DEVOPS_AREA_PATH=

# Optional — override the sprint workspace root.
# Default: <repo-root>/docs/sprints
# SPRINT_WORKSPACE=

# Optional — override the export / report directory.
# Default: <SPRINT_WORKSPACE>/Sprint-<N>/export
# EXPORT_DIR=

# Optional — override the transient cache / log directory.
# Default: <tool>/.temp/devops-push
# TEMP_DIR=
