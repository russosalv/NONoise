      "group": "build"
    },
    {
      "label": "npm: build",
      "type": "shell",
      "command": "npm run build",
      "detail": "generated by vscode-config-generator",
      "group": "build"
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm test",
      "detail": "generated by vscode-config-generator",
      "group": { "kind": "test", "isDefault": true }
    }
  ]
}
",
  ".claude/skills/vscode-config-generator/assets/tasks.python.json.hbs": "{
